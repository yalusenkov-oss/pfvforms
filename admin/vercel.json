{
    "functions": {
        "api/sign.js": {
            "maxDuration": 60
        },
        "api/send-contract.js": {
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/:path*"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}