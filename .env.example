# Пример файла окружения для Vite
# Скопируйте в .env и подставьте URL вашего развернутого Google Apps Script
VITE_GOOGLE_SCRIPT_URL="https://script.google.com/macros/s/ВАШ_ID/exec"

# YooKassa Payment (https://yookassa.ru/my/shop-settings)
YOOKASSA_SHOP_ID=ваш_shop_id
YOOKASSA_SECRET_KEY=live_ваш_секретный_ключ

# Site URL (used for payment return URL)
SITE_URL=https://pfvmusic.digital
