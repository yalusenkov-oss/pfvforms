function saveDistribution(data) {
  try {
    initializeSheets();
    const sheet = SpreadsheetApp.openById(SPREADSHEET_ID).getSheetByName(DISTRIBUTION_SHEET_NAME);
    if (!sheet) throw new Error('Sheet "' + DISTRIBUTION_SHEET_NAME + '" not found');

    const contractNumber = generateContractNumber();
    const percentage = getTariffPercentage(data.tariff);

    const tracksArray = normalizeTracksInput(data.tracks || data.tracks_json || []);
    const authorsFromTracks = extractAuthorsFromTracks(tracksArray);
    const musicAuthorValue = (data.musicAuthor && String(data.musicAuthor).trim())
      ? data.musicAuthor
      : (authorsFromTracks.composers.length ? authorsFromTracks.composers.join(', ') : (data.fullName || ''));
    const lyricsAuthorValue = (data.lyricsAuthor && String(data.lyricsAuthor).trim())
      ? data.lyricsAuthor
      : (authorsFromTracks.lyricists.length ? authorsFromTracks.lyricists.join(', ') : (data.fullName || ''));

    // ── Автоматически генерируем ссылку на подписание ──────────────────────
    const tariffName      = getTariffName(data.tariff);
    const releaseTypeName = getReleaseTypeName(data.releaseType);
    const signToken       = generateSignToken();
    const signExpiresDays = 14;
    const expiresAt       = new Date();
    expiresAt.setDate(expiresAt.getDate() + signExpiresDays);
    const signBaseUrl     = 'https://pfvmusic.digital';
    const signUrl         = signBaseUrl + '/#sign?token=' + signToken;

    // Генерируем HTML договора прямо здесь
    const contractHtml = generateContractHTMLInGAS({
      contractNumber:       contractNumber,
      licensorName:         data.fullName || '',
      passportSeriesNumber: data.passportNumber || '',
      passportIssuedBy:     data.issuedBy || '',
      passportIssueDate:    data.issueDate || '',
      bankDetails:          data.bankDetails || '',
      email:                data.email || '',
      pseudonym:            data.mainArtist || '',
      workTitle:            data.releaseName || '',
      musicAuthor:          musicAuthorValue || '',
      lyricsAuthor:         lyricsAuthorValue || '',
      tariff:               tariffName,
      percentage:           percentage,
      releaseType:          releaseTypeName
    });

    // Встраиваем подпись лицензиата (ОР) в HTML и сохраняем на Drive
    const htmlWithOwnerSig = embedOwnerSignatureInHtml(contractHtml);
    const licensorName_    = data.fullName || 'Без имени';
    const fileName_        = 'Договор №' + contractNumber + ' - ' + licensorName_;
    const stored           = storeContractHtml(htmlWithOwnerSig, fileName_, '');

    const row = [
      new Date(data.timestamp || new Date()),
      tariffName,
      releaseTypeName,
      data.trackCount || 0,
      data.releaseName || '',
      data.mainArtist || '',
      data.releaseVersion || '',
      data.releaseLink || '',
      data.genre || '',
      data.language || '',
      data.releaseDate || '',
      data.coverLink || '',
      data.tiktokExcerpt || '',
      data.tiktokFull || '',
      data.yandexPreSave || '',
      data.addKaraoke === 'yes' ? 'Да' : 'Нет',
      JSON.stringify(tracksArray, null, 2),
      data.fullName || '',
      data.passportNumber || '',
      data.issuedBy || '',
      data.issueDate || '',
      data.bankDetails || '',
      data.email || '',
      data.contactInfo || '',
      data.artistProfileLinks || '',
      Number(data.basePrice || 0),
      Number(data.karaokePrice || 0),
      Number(data.totalPrice || 0),
      '',                              // payment_proof_url — заполним ниже асинхронно
      contractNumber,
      percentage + '%',
      '',                              // contract_status
      musicAuthorValue || '',
      lyricsAuthorValue || '',
      collectLyricsFromTracks(tracksArray) || '',
      '',                              // document_status
      '',                              // telegram_status
      'pending',                       // sign_status ← выставляем сразу
      signToken,                       // sign_token
      expiresAt.toISOString(),         // sign_expires_at
      signUrl,                         // sign_link
      '',                              // sign_doc_id
      '',                              // signed_url
      '',                              // signed_at
      stored.value,                    // contract_html
      'internal',                      // sign_source
      '',                              // signed_pdf_id
      data.platforms || ''             // platforms
    ];

    sheet.appendRow(row);

    const lastRow = sheet.getLastRow();
    if (lastRow % 2 === 0) {
      sheet.getRange(lastRow, 1, 1, row.length).setBackground('#F9F9F9');
    }

    Logger.log('Distribution data saved successfully. Contract: ' + contractNumber);
    Logger.log('Sign link auto-generated: ' + signUrl);

    // ── Telegram-уведомление — ПЕРВЫМ, до медленных операций ────────────────
    const distCfg = getTelegramConfig('distribution');
    if (TELEGRAM_CONFIG.NOTIFY_DISTRIBUTION && distCfg.ENABLED && distCfg.BOT_TOKEN && distCfg.CHAT_ID) {
      try {
        sendDistributionNotification({
          contractNumber: contractNumber,
          licensorName:   data.fullName || '',
          pseudonym:      data.mainArtist || '',
          tariff:         tariffName,
          releaseType:    releaseTypeName,
          releaseDate:    data.releaseDate || '',
          workTitle:      data.releaseName || '',
          musicAuthor:    musicAuthorValue || '',
          lyricsAuthor:   lyricsAuthorValue || '',
          platforms:      data.platforms || '',
          email:          data.email || '',
          contact:        data.contactInfo || '',
          sheetUrl:       SpreadsheetApp.getActiveSpreadsheet().getUrl()
        });
      } catch (tgErr) {
        Logger.log('❌ Telegram distribution error: ' + tgErr);
      }
    }

    // ── Telegram-уведомление: договор создан и отправлен ──────────────────────
    const docCfgDist = getTelegramConfig('document');
    if (TELEGRAM_CONFIG.NOTIFY_DOC_GENERATED && docCfgDist.ENABLED && docCfgDist.BOT_TOKEN && docCfgDist.CHAT_ID) {
      try {
        sendDocumentGeneratedNotification({
          contractNumber: contractNumber,
          licensorName:   data.fullName || '',
          pseudonym:      data.mainArtist || '',
          workTitle:      data.releaseName || '',
          docUrl:         signUrl
        });
        Logger.log('✅ Telegram: уведомление о договоре отправлено');
      } catch (tgErr) {
        Logger.log('❌ Telegram document error: ' + tgErr);
      }
    }

    // ── Email-данные возвращаем в ответе — Vercel отправит через Yandex SMTP ──
    if (data.email) {
      Logger.log('📧 Email-данные переданы Vercel для отправки через Yandex SMTP');
    }

    // ── Загрузка скриншота оплаты на Drive (медленная операция — после уведомлений) ──
    if (data.paymentProof) {
      try {
        const proofFile = storePaymentProof(data.paymentProof, contractNumber, data.fullName || '');
        if (proofFile) {
          const proofUrl = proofFile.getUrl();
          const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
          const proofColIdx = headers.indexOf('payment_proof_url');
          if (proofColIdx >= 0) {
            sheet.getRange(lastRow, proofColIdx + 1).setValue(proofUrl);
          }
          Logger.log('✅ Скриншот оплаты загружен: ' + proofUrl);
        }
      } catch (e) {
        Logger.log('saveDistribution paymentProof error: ' + e);
      }
    }

    return {
      success: true,
      message: 'Данные успешно сохранены',
      formType: 'distribution',
      emailData: data.email ? {
        email:          data.email,
        name:           data.fullName || '',
        contractNumber: contractNumber,
        signLink:       signUrl,
        workTitle:      data.releaseName || '',
        releaseType:    releaseTypeName
      } : null
    };

  } catch (error) {
    Logger.log('saveDistribution error: ' + error.toString());
    throw error;
  }
}

