  sheet.copyTo(spreadsheet).setName(backupName);
}

function looksLikeUrl(value) {
  return /^https?:\/\//i.test(String(value || '').trim());
}

function looksLikeIsoDate(value) {
  return /^\d{4}-\d{2}-\d{2}T/.test(String(value || '').trim());
}

function looksLikeInternalSource(value) {
  return String(value || '').trim() === 'internal';
}

function looksLikeDriveId(value) {
  return /^[A-Za-z0-9_-]{20,}$/.test(String(value || '').trim());
}

function fixSignColumnsShift(force) {
  const spreadsheet = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = spreadsheet.getSheetByName(DISTRIBUTION_SHEET_NAME);
  if (!sheet) {
    SpreadsheetApp.getActiveSpreadsheet().toast('Лист "Дистрибуция" не найден', 'Ошибка', 5);
    return;
  }

  const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
  const signDocIdIdx = headers.indexOf('sign_doc_id');
  const signedUrlIdx = headers.indexOf('signed_url');
  const signedAtIdx = headers.indexOf('signed_at');
  const contractHtmlIdx = headers.indexOf('contract_html');
  const signSourceIdx = headers.indexOf('sign_source');
  const signedPdfIdIdx = headers.indexOf('signed_pdf_id');

  if ([signDocIdIdx, signedUrlIdx, signedAtIdx, contractHtmlIdx, signSourceIdx, signedPdfIdIdx].some(i => i < 0)) {
    SpreadsheetApp.getActiveSpreadsheet().toast('Не найдены колонки блока подписи', 'Ошибка', 5);
    return;
  }

  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();
  if (lastRow < 2) {
    SpreadsheetApp.getActiveSpreadsheet().toast('Нет данных для исправления', 'Ок', 4);
    return;
  }

  const data = sheet.getRange(2, 1, lastRow - 1, lastCol).getValues();
  let fixed = 0;

  for (let r = 0; r < data.length; r++) {
    const row = data[r];
    const signDocId = row[signDocIdIdx];
    const signedUrl = row[signedUrlIdx];
    const signedAt = row[signedAtIdx];
    const contractHtml = row[contractHtmlIdx];
    const signSource = row[signSourceIdx];
    const signedPdfId = row[signedPdfIdIdx];

    const shiftedPattern =
      looksLikeUrl(signDocId) &&
      looksLikeIsoDate(signedUrl) &&
      looksLikeUrl(signedAt) &&
      looksLikeInternalSource(contractHtml);

    const tailShiftPattern =
      looksLikeIsoDate(contractHtml) &&
      looksLikeUrl(signSource) &&
      (looksLikeInternalSource(signedPdfId) || !String(signedPdfId || '').trim() || !!force);

    if (shiftedPattern) {
      // Кейc 1: sign_doc_id -> signed_url -> signed_at -> contract_html сдвинуты вправо.
      row[signedPdfIdIdx] = looksLikeDriveId(signSource) ? String(signSource).trim() : extractDriveFileId(signDocId) || signedPdfId || '';
      row[signSourceIdx] = 'internal';
      row[contractHtmlIdx] = signedAt || '';
      row[signedAtIdx] = signedUrl || '';
      row[signedUrlIdx] = signDocId || '';
      row[signDocIdIdx] = '';
      fixed++;
      continue;
    }

    if (tailShiftPattern) {
      // Кейc 2: сдвинут только хвост contract_html/sign_source/signed_pdf_id.
      const recoveredPdfId =
        looksLikeDriveId(signedPdfId) ? String(signedPdfId).trim() :
        extractDriveFileId(signedUrl) || extractDriveFileId(signSource) || '';
      row[contractHtmlIdx] = signSource || '';
      row[signSourceIdx] = 'internal';
      row[signedPdfIdIdx] = recoveredPdfId;
      fixed++;
    }
  }

  if (fixed > 0) {
    backupDistributionSheet();
    sheet.getRange(2, 1, data.length, lastCol).setValues(data);
    SpreadsheetApp.getActiveSpreadsheet().toast(`Исправлено подписи: ${fixed}`, 'Готово', 6);
  } else {
    SpreadsheetApp.getActiveSpreadsheet().toast('Сдвиг в блоке подписи не обнаружен', 'Ок', 4);
  }
}

function fixSignColumnsShiftForce() {
  fixSignColumnsShift(true);
}

