function sendToTelegramAPI(message, cfg) {
  const url = `https://api.telegram.org/bot${cfg.BOT_TOKEN}/sendMessage`;
  const baseChatId = String(cfg.CHAT_ID || '').trim();
  if (!baseChatId) throw new Error('Telegram CHAT_ID is empty');

  const chatIdsToTry = buildTelegramChatCandidates(baseChatId);

  let lastError;

  for (const chatId of chatIdsToTry) {
    try {
      const payload = {
        chat_id: chatId,
        text: message,
        parse_mode: "MarkdownV2",
        disable_web_page_preview: false
      };

      // thread работает только в супергруппах/форумах
      if (shouldAttachThread(chatId, cfg.THREAD_ID)) {
        payload.message_thread_id = Number(cfg.THREAD_ID);
      }

      const response = UrlFetchApp.fetch(url, {
        method: "post",
        contentType: "application/json",
        payload: JSON.stringify(payload),
        muteHttpExceptions: true
      });

      const responseData = JSON.parse(response.getContentText());
      if (responseData.ok) return responseData;

      lastError = `${chatId}: ${responseData.description || 'unknown error'}`;
    } catch (e) {
      lastError = `${chatId}: ${e.message}`;
    }
  }

  throw new Error(`Telegram API: ${lastError || "Не удалось отправить сообщение"}`);
}

function buildTelegramChatCandidates(chatId) {
  const id = String(chatId || '').trim();
  if (!id) return [];
  if (id[0] === '@' || id.indexOf('-100') === 0) return [id];
  return [id, `-100${id}`, `@${id}`];
}

function shouldAttachThread(chatId, threadId) {
  const tid = Number(threadId);
  if (!Number.isFinite(tid) || tid <= 0) return false;
  return String(chatId || '').indexOf('-100') === 0;
}

function sendDebugInfo(text, cfg) {
  if (!cfg || !cfg.DEBUG_MODE || !cfg.BOT_TOKEN || !cfg.CHAT_ID) {
    return;
  }

  try {
    const debugUrl = `https://api.telegram.org/bot${cfg.BOT_TOKEN}/sendMessage`;
    const payload = {
      chat_id: cfg.CHAT_ID,
      text: "🛠 DEBUG:\n" + text,
      parse_mode: "MarkdownV2"
    };

    if (shouldAttachThread(cfg.CHAT_ID, cfg.THREAD_ID)) {
      payload.message_thread_id = Number(cfg.THREAD_ID);
    }

    UrlFetchApp.fetch(debugUrl, {
      method: "post",
      contentType: "application/json",
      payload: JSON.stringify(payload),
      muteHttpExceptions: true
    });
  } catch (e) {
    Logger.log("Не удалось отправить debug info: " + e);
  }
}

