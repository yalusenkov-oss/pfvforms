  };

  const messageParts = [
    "\\#дистрибуция *Новая заявка получена*\\!",
    "",
    "📝 *Основные данные*",
    `▸ №: ${escapeMd(data.contractNumber)}`,
    `▸ Лицензиар: ${escapeMd(data.licensorName)}`,
    `▸ Псевдоним: ${escapeMd(data.pseudonym || 'не указан')}`,
    `▸ Тариф: ${escapeMd(data.tariff)}`,
    `▸ Тип релиза: ${escapeMd(data.releaseType || 'не указан')}`,
    `▸ Дата релиза: ${escapeMd(data.releaseDate || 'не указана')}`,
    "",
    "🎵 *Произведение*",
    `▸ Название: ${escapeMd(data.workTitle || 'не указано')}`,
    `▸ Автор музыки: ${escapeMd(data.musicAuthor)}`,
    `▸ Автор текста: ${escapeMd(data.lyricsAuthor)}`,
