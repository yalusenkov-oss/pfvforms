    'basic': 55, 'Базовый': 55, 'базовый': 55,
    'advanced': 70, 'Продвинутый': 70, 'продвинутый': 70,
    'premium': 90, 'Премиум': 90, 'премиум': 90,
    'platinum': 95, 'Платинум': 95, 'платинум': 95
  };
  return percentages[tariff] || 55;
}

function getTariffName(tariff) {
