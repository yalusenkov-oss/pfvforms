// ═══════════════════════════════════════════════════════════════════════════
// Диагностика Telegram — запустите эту функцию в редакторе GAS для проверки
// ═══════════════════════════════════════════════════════════════════════════
function diagnoseTelegram() {
  const lines = [];

  const configs = [
    { name: 'DISTRIBUTION', cfg: getTelegramConfig('distribution') },
    { name: 'PROMO', cfg: getTelegramConfig('promo') },
    { name: 'DOCUMENT', cfg: getTelegramConfig('document') }
  ];

  for (const entry of configs) {
    const cfg = entry.cfg;
    lines.push('=== ' + entry.name + ' ===');
    lines.push('ENABLED: ' + cfg.ENABLED);
    lines.push('BOT_TOKEN: ' + (cfg.BOT_TOKEN ? cfg.BOT_TOKEN.substring(0, 12) + '...' : 'MISSING'));
    lines.push('CHAT_ID: ' + (cfg.CHAT_ID || 'MISSING'));
    lines.push('THREAD_ID: ' + (cfg.THREAD_ID || 'нет'));

    if (!cfg.ENABLED || !cfg.BOT_TOKEN || !cfg.CHAT_ID) {
      lines.push('→ ПРОПУЩЕН (не настроен)');
      lines.push('');
      continue;
    }

    // Check bot token via getMe
    try {
      const getMeResp = UrlFetchApp.fetch(
        'https://api.telegram.org/bot' + cfg.BOT_TOKEN + '/getMe',
        { muteHttpExceptions: true }
      );
      const getMeData = JSON.parse(getMeResp.getContentText());
      if (getMeData.ok) {
        lines.push('Bot: @' + getMeData.result.username + ' OK');
      } else {
        lines.push('Bot: ОШИБКА — ' + getMeData.description);
        lines.push('');
        continue;
      }
    } catch (e) {
      lines.push('Bot: запрос упал — ' + e.message);
      lines.push('');
      continue;
    }

    // Send a test ping message
    try {
      const testMsg = 'Тест PFVMUSIC [' + entry.name + '] — ' + new Date().toLocaleString('ru-RU');
      const candidates = buildTelegramChatCandidates(String(cfg.CHAT_ID));
      let sent = false;
      for (const chatId of candidates) {
        const payload = { chat_id: chatId, text: testMsg };
        if (shouldAttachThread(chatId, cfg.THREAD_ID)) {
          payload.message_thread_id = Number(cfg.THREAD_ID);
        }
        const resp = UrlFetchApp.fetch(
          'https://api.telegram.org/bot' + cfg.BOT_TOKEN + '/sendMessage',
          { method: 'post', contentType: 'application/json', payload: JSON.stringify(payload), muteHttpExceptions: true }
        );
        const respData = JSON.parse(resp.getContentText());
        if (respData.ok) {
          lines.push('Отправка chatId ' + chatId + ': OK');
          sent = true;
          break;
        } else {
          lines.push('Отправка chatId ' + chatId + ': ОШИБКА ' + respData.description);
        }
      }
      if (!sent) lines.push('Не удалось отправить ни в один chatId');
    } catch (e) {
      lines.push('Ошибка отправки: ' + e.message);
    }
    lines.push('');
  }

  const report = lines.join('\n');
  Logger.log('=== ДИАГНОСТИКА TELEGRAM ===\n' + report);

  // Toast works only when run from the spreadsheet, not from the script editor —
  // results are always available in the Logs panel (Ctrl+Enter / View > Logs)
  try {
    SpreadsheetApp.getActiveSpreadsheet().toast(
      'Готово! Откройте Журналы выполнения чтобы увидеть результат.',
      'Диагностика Telegram',
      10
    );
  } catch (e) {
    // Running from script editor — results are in the execution log
  }
}
