// Исправление сдвига колонок после добавления payment_proof_url
// ═══════════════════════════════════════════════════════════════════════════
function fixPaymentProofColumn(force) {
  const spreadsheet = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = spreadsheet.getSheetByName(DISTRIBUTION_SHEET_NAME);
  if (!sheet) {
    SpreadsheetApp.getActiveSpreadsheet().toast('Лист "Дистрибуция" не найден', 'Ошибка', 5);
    return;
  }

  const headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
  const proofIdx = headers.indexOf('payment_proof_url');
  const contractIdx = headers.indexOf('contract_number');
  if (proofIdx < 0 || contractIdx < 0) {
    SpreadsheetApp.getActiveSpreadsheet().toast('Не найдены нужные колонки', 'Ошибка', 5);
    return;
  }

  const lastRow = sheet.getLastRow();
  const lastCol = sheet.getLastColumn();
  if (lastRow < 2) {
    SpreadsheetApp.getActiveSpreadsheet().toast('Нет данных для исправления', 'Ок', 4);
    return;
  }

  const data = sheet.getRange(2, 1, lastRow - 1, lastCol).getValues();
  let fixed = 0;

  for (let r = 0; r < data.length; r++) {
    const row = data[r];
    const proofVal = String(row[proofIdx] || '').trim();
    const contractVal = String(row[contractIdx] || '').trim();
    const looksLikeContract = /^PFV-\d{6}-\d{4}/.test(proofVal);
    const looksLikeUrl = /^https?:\/\//i.test(proofVal);
    const contractLooksValid = /^PFV-\d{6}-\d{4}/.test(contractVal);
    const shouldShift = !!force || (looksLikeContract && !looksLikeUrl && !contractLooksValid);

    if (shouldShift) {
      // Сдвигаем значения вправо на 1, начиная с payment_proof_url
      for (let c = lastCol - 1; c > proofIdx; c--) {
        row[c] = row[c - 1];
      }
      row[proofIdx] = '';
      fixed++;
    }
  }

  if (fixed > 0) {
    sheet.getRange(2, 1, data.length, lastCol).setValues(data);
    SpreadsheetApp.getActiveSpreadsheet().toast(
      `Исправлено строк: ${fixed}`,
      'Готово',
      5
    );
  } else {
    SpreadsheetApp.getActiveSpreadsheet().toast('Сдвиг не обнаружен', 'Ок', 4);
  }
}

function fixPaymentProofColumnForce() {
  fixPaymentProofColumn(true);
}

function backupDistributionSheet() {
  const spreadsheet = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheet = spreadsheet.getSheetByName(DISTRIBUTION_SHEET_NAME);
