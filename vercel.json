{
    "functions": {
        "api/submit.js": {
            "maxDuration": 60
        },
        "api/sign.js": {
            "maxDuration": 60
        },
        "api/send-contract.js": {
            "maxDuration": 30
        },
        "api/test-email.js": {
            "maxDuration": 20
        },
        "api/payment/create.js": {
            "maxDuration": 30
        },
        "api/payment/status.js": {
            "maxDuration": 15
        },
        "api/payment/webhook.js": {
            "maxDuration": 30
        },
        "api/upload-cover.js": {
            "maxDuration": 60
        }
    },
    "rewrites": [
        {
            "source": "/admin",
            "destination": "/admin/index.html"
        },
        {
            "source": "/admin/:path*",
            "destination": "/admin/index.html"
        },
        {
            "source": "/api/:path*",
            "destination": "/api/:path*"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}
